# One of these is required on the free tier.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Which provider to use for framing. Options: anthropic, openai.
BODHISATTVA_LLM_PROVIDER=anthropic

# Model ID for the provider. Defaults chosen for low-latency framing.
# Anthropic: claude-haiku-4-5-20251001
# OpenAI:    gpt-4o-mini
BODHISATTVA_LLM_MODEL=claude-haiku-4-5-20251001

# Optional: override default journal location.
# BODHISATTVA_JOURNAL_PATH=

# Local web UI port.
BODHISATTVA_WEB_PORT=8473
